# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openjkn
OPENIMIS_DATABASE_URL=postgresql://IMISuser:IMISuserP@s@localhost:5432/IMIS
# Legacy MySQL (Optional - only for migration)
LEGACY_DATABASE_URL=mysql://root@localhost:3306/simpbb

# Better Auth Configuration
BETTER_AUTH_URL=https://open-jkn.technosmart.id
# Generate with: openssl rand -base64 32  (must be at least 32 characters)
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
NEXT_PUBLIC_BETTER_AUTH_URL=https://open-jkn.technosmart.id

# Application URLs
NEXT_PUBLIC_APP_URL=https://open-jkn.technosmart.id

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google reCAPTCHA (Optional)
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Email Service (Resend - Recommended)
RESEND_API_KEY=re-your-api-key-here

# SatuSehat Integration (FHIR R4 API)
SATUSEHAT_API_URL=https://api-satusehat.kemkes.go.id/fhir-r4
SATUSEHAT_AUTH_URL=https://api-satusehat.kemkes.go.id/oauth2/v1
SATUSEHAT_CLIENT_ID=your-satusehat-client-id
SATUSEHAT_CLIENT_SECRET=your-satusehat-client-secret
SATUSEHAT_ORGANIZATION_ID=your-organization-id

# AI / Anomaly Detection
# Python interpreter used by the AI scoring/training scripts. Defaults to "python3";
# override when python3 is not on PATH in your deployment (e.g. /usr/bin/python3).
PYTHON_BIN=python3
